{
  "brand": "Ghostd",
  "typography": {
    "display_font": "Playfair Display, Georgia, serif",
    "body_font": "DM Sans, system-ui, sans-serif",
    "import_url": "https://fonts.googleapis.com/css2?family=Playfair+Display:wght@400;500&family=DM+Sans:wght@400;500&display=swap",
    "weights": { "regular": 400, "medium": 500 },
    "heading_letter_spacing": "-0.02em",
    "body_line_height": 1.6,
    "usage": {
      "playfair": "page headings (h1/h2), logo wordmark, section titles, modal headers, ATS score number",
      "dm_sans": "all body text, labels, nav links, buttons, card content, form inputs, tags, pills"
    }
  },
  "colors": {
    "background": "#F7F5F0",
    "card": "#FFFFFF",
    "text_primary": "#1C1917",
    "text_muted": "#9B8B7A",
    "border": "#E5E0D8",
    "accent": "#C0A882",
    "success": "#2D6A4F",
    "warning": "#C77B3F",
    "danger": "#B54A3F",
    "nav_bg": "#1C1917",
    "nav_text": "#F7F5F0",
    "status_pills": {
      "applied": { "bg": "#F7F5F0", "text": "#1C1917" },
      "ghosted": { "bg": "#F0EDEA", "text": "#9B8B7A" },
      "interview": { "bg": "#F0EDE6", "text": "#C0A882" },
      "offer": { "bg": "#EAF2EC", "text": "#2D6A4F" },
      "saved": { "bg": "#F7F5F0", "text": "#9B8B7A" }
    }
  },
  "components": {
    "border_radius": { "card": "10px", "button": "6px", "pill": "20px" },
    "shadows": "none — borders only",
    "card_hover": "border-color changes from #E5E0D8 to #C0A882",
    "active_card": "left border 2px solid #C0A882",
    "button_primary": { "bg": "#1C1917", "text": "#F7F5F0", "radius": "6px" },
    "button_ghost": { "bg": "transparent", "border": "1px solid #1C1917", "text": "#1C1917" },
    "input": { "bg": "#FFFFFF", "border": "1px solid #E5E0D8", "radius": "6px", "focus_border": "#C0A882" }
  },
  "navigation": {
    "bg": "#1C1917",
    "height": "52px",
    "logo": "ghostd in Playfair Display 18px #F7F5F0 followed by ● in #C0A882 8px",
    "links": "DM Sans 13px, inactive #9B8B7A, active #F7F5F0",
    "ask_ghost_button": { "bg": "#C0A882", "text": "#1C1917", "font": "DM Sans 12px 500" }
  },
  "ghosted_treatment": "opacity: 0.45, avatar bg becomes #9B8B7A, all text #9B8B7A"
}
